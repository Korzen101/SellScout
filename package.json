{
  "name": "sellscout",
  "productName": "SellScout",
  "version": "1.2.0",
  "description": "Product research, sourcing, and profit analytics for Amazon sellers",
  "main": "main.js",
  "author": "Chris Korzen",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "preview": "node tools/preview-server.js",
    "test": "node --test tests/fees.test.js tests/scoring.test.js tests/actuals.test.js",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.korzen.sellscout",
    "productName": "SellScout",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/sellscout.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Korzen101",
      "repo": "SellScout",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
